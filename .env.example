# Supabase (인증 · 공유 데이터) — 필수
# Supabase 대시보드 → Project Settings → API 에서 확인
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# 지표 실측 백엔드 (선택) — 기본은 같은 배포의 /api/metrics 서버리스 함수를 사용.
# 다른 주소의 백엔드를 쓸 때만 지정한다.
# VITE_METRICS_API_URL=https://api.example.com/metrics

# ── 서버 전용 (Vercel 환경변수에만 등록, VITE_ 접두사 없음 → 클라이언트 비노출) ──
# 인스타 실측 수집(api/metrics.js, Business Discovery)에 필요.
# IG_USER_ID=<내 인스타 비즈니스 계정의 IG User ID>
# IG_ACCESS_TOKEN=<장기 액세스 토큰>
# GRAPH_VERSION=v21.0
